# Kaizen — environment variables
# Copy to .env (gitignored) and fill in values.

# Database — Neon Postgres pooled connection string
DATABASE_URL=

# Anthropic Claude (capture, summarization, project chat)
ANTHROPIC_API_KEY=

# Auth — magic link sessions
JWT_SECRET=                          # generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
RESEND_API_KEY=                      # https://resend.com/api-keys
EMAIL_FROM=Kaizen <onboarding@resend.dev>  # change to your verified Resend domain in prod
APP_URL=http://localhost:3000        # set to https://your-domain in prod

# Bearer token for the macOS Quick Todo capture app
CAPTURE_TOKEN=
FOUNDER_EMAIL=emcohen@me.com         # user that bearer-token / cron endpoints attach data to (also gates founder-only Dropbox routes)

# File uploads — Vercel Blob (Project → Storage → Connect Blob)
BLOB_READ_WRITE_TOKEN=

# Optional anti-abuse
# MAX_SIGNUPS_PER_DAY=50             # cap new signups per 24h (0 / unset = unlimited)
# INVITE_TOKEN=                      # if set, only /signup?invite=<this> can create new accounts
