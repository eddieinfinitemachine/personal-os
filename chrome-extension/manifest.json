{
  "manifest_version": 3,
  "name": "Kaizen Capture",
  "version": "0.1.0",
  "description": "Send the current tab to your Kaizen smart-capture inbox. Auto-classifies as bookmark / todo / person / place / etc.",
  "permissions": ["activeTab", "storage", "contextMenus", "notifications", "scripting"],
  "host_permissions": [
    "https://internal.eddiecohen.com/*",
    "https://kaizen.eddiecohen.com/*",
    "https://personal-os-two-gold.vercel.app/*"
  ],
  "action": {
    "default_title": "Capture to Kaizen",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+L"
      },
      "description": "Open Kaizen capture popup for current tab"
    },
    "quick-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "Send current tab to Kaizen (no popup)"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
